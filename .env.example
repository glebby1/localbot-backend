# ─────────────────────────────────────────────
# ANTHROPIC — Claude API
# ─────────────────────────────────────────────
# Clé API Anthropic pour appeler Claude
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# META — WhatsApp & Instagram
# ─────────────────────────────────────────────
# Token de vérification du webhook Meta (valeur libre, à définir lors du setup)
META_VERIFY_TOKEN=

# Secret de l'application Meta (pour valider la signature des webhooks entrants)
META_APP_SECRET=

# Token d'accès permanent WhatsApp Business API
WHATSAPP_TOKEN=

# Token d'accès Instagram Graph API
INSTAGRAM_TOKEN=

# ─────────────────────────────────────────────
# GOOGLE — Calendar API (OAuth2)
# ─────────────────────────────────────────────
# Client ID de l'application Google Cloud (OAuth2)
GOOGLE_CLIENT_ID=

# Client Secret de l'application Google Cloud (OAuth2)
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# SENDGRID — Emails transactionnels
# ─────────────────────────────────────────────
# Clé API SendGrid pour l'envoi d'emails
SENDGRID_API_KEY=

# Adresse email expéditeur vérifiée dans SendGrid
SENDGRID_FROM_EMAIL=no-reply@localbot.fr

# ─────────────────────────────────────────────
# STRIPE — Paiements & abonnements SaaS
# ─────────────────────────────────────────────
# Clé secrète Stripe (sk_live_... en prod, sk_test_... en dev)
STRIPE_SECRET_KEY=

# Secret du webhook Stripe (whsec_...) pour valider les événements entrants
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# BUBBLE — Base de données no-code
# ─────────────────────────────────────────────
# Clé API Bubble pour les appels Data API
BUBBLE_API_KEY=

# URL de base de l'application Bubble (ex: https://monapp.bubbleapps.io/api/1.1)
BUBBLE_APP_URL=

# ─────────────────────────────────────────────
# SERVEUR
# ─────────────────────────────────────────────
# Port d'écoute du serveur Express (défaut : 3000)
PORT=3000

# Environnement d'exécution : development | production
NODE_ENV=development
